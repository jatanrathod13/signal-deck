# Server
PORT=3001

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Model Provider (recommended)
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
DEFAULT_MODEL=gpt-4o-mini

# Fallback if not using AI Gateway
OPENAI_API_KEY=

# Tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agent-orchestration

# Dev fallback when no model key is configured
MOCK_AGENT_FALLBACK=true

# Feature Flags (staged rollout)
FEATURE_DEEP_RESEARCH=false
FEATURE_MCP_SDK_CLIENT=false
FEATURE_PROVIDER_TOOLS=false
FEATURE_EVALUATOR_LOOP=false
FEATURE_APPROVAL_GATES=false
FEATURE_RUN_INTELLIGENCE_UI=false
FEATURE_RESUMABLE_STREAM_TRANSPORT=false
